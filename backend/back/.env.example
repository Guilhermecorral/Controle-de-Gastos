SPRING_DATASOURCE_USERNAME=controle_gastos_app
SPRING_DATASOURCE_PASSWORD=troque-por-uma-senha-forte

POSTGRES_USER=controle_gastos_db
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Use pelo menos 32 caracteres e prefira um segredo gerado por gerenciador de senhas.
JWT_SECRET=troque-por-um-segredo-longo-com-pelo-menos-32-caracteres
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Lista separada por virgula das origens autorizadas do frontend.
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,https://farolfinanceiro.online,https://www.farolfinanceiro.online

# Apenas estes e-mails podem receber role ADMIN.
APP_ADMIN_ALLOWED_EMAILS=

# Cookies seguros da sessao.
APP_ACCESS_COOKIE_NAME=cg_access_token
APP_REFRESH_COOKIE_NAME=cg_refresh_token
APP_COOKIES_SECURE=false
APP_COOKIES_SAME_SITE=Lax
APP_COOKIES_DOMAIN=

# Limites simples contra abuso nas rotas publicas de autenticacao.
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_RATE_LIMIT_MAX_ATTEMPTS=12
APP_AUTH_RATE_LIMIT_REDIS_ENABLED=false

# Logs temporarios de diagnostico para investigar CORS, cookies e autorizacao.
APP_SECURITY_REQUEST_DEBUG_ENABLED=false

# Captcha e anti-bot.
APP_CAPTCHA_ENABLED=false
# Secret Key privada do widget Turnstile. Nao use aqui a Site Key publica do frontend.
APP_CAPTCHA_SECRET_KEY=
APP_CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Recuperacao de senha.
APP_PASSWORD_RESET_FRONTEND_URL=https://farolfinanceiro.online/redefinir-senha
APP_PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
APP_PASSWORD_RESET_MAIL_FROM=no-reply@farolfinanceiro.local

# SMTP opcional para envio real de emails.
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true

# Redis opcional para rate limiting distribuido em multi-instancia.
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

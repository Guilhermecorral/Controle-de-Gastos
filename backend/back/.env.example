SPRING_DATASOURCE_USERNAME=controle_gastos_app
SPRING_DATASOURCE_PASSWORD=troque-por-uma-senha-forte

POSTGRES_USER=controle_gastos_db
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Use pelo menos 32 caracteres e prefira um segredo gerado por gerenciador de senhas.
JWT_SECRET=troque-por-um-segredo-longo-com-pelo-menos-32-caracteres
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Lista separada por virgula das origens autorizadas do frontend.
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Limites simples contra abuso nas rotas publicas de autenticacao.
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_AUTH_RATE_LIMIT_MAX_ATTEMPTS=12
